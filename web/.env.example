# ── Local development (SQLite — works out of the box) ──────────────────
DATABASE_URL="file:./dev.db"

# ── Production (Supabase Postgres) ──────────────────────────────────────
# Uncomment and replace DATABASE_URL above when switching to Supabase.
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── AI Enrichment (Anthropic) ───────────────────────────────────────────
# Required to run: classify-cuisine.ts, classify-dietary.ts, ai-enrich.ts
ANTHROPIC_API_KEY=""

# ── Google Maps ─────────────────────────────────────────────────────────
# Required for the /map page
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# ── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://www.indianrestaurantsinusa.com"
