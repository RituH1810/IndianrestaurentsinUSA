generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Restaurant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  address         String
  street          String?
  city            String
  state           String
  state_abbr      String?
  metro           String?
  zip             String?
  county          String?
  latitude        Float?
  longitude       Float?
  phone           String?
  website         String?
  rating          Float?
  reviews         Int?
  price_level     Int?
  photo           String?
  street_view     String?
  working_hours   String?
  business_status String   @default("OPERATIONAL")
  description     String?
  cuisine_tags    String?
  dietary_tags    String?
  is_hidden_gem   Boolean  @default(false)
  publish_priority Int     @default(0)
  is_published    Boolean  @default(false)
  located_in      String?
  reviews_tags    String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}
